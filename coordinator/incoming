<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Coordinators Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --bg:        #0A0A0B;
    --surface:   #131316;
    --surface-2: #1A1A1D;
    --border:    #27272B;
    --border-strong: #3A3A40;
    --text:      #FAFAFB;
    --text-2:    #ECECEE;
    --muted:     #9A9AA1;
    --muted-2:   #6E6E76;
    --green:     #4ADE80;
    --green-bg:  rgba(74,222,128,0.1);
    --orange:    #FBBF24;
    --orange-bg: rgba(251,191,36,0.1);
    --red:       #F87171;
    --red-bg:    rgba(248,113,113,0.1);
    --purple:    #C084FC;
    --purple-bg: rgba(192,132,252,0.1);
    --brand:     #E07A1A;
    --day:       #FBBF24;
    --day-bg:    rgba(251,191,36,0.12);
    --night:     #818CF8;
    --night-bg:  rgba(129,140,248,0.12);
    --grid:      rgba(255,255,255,0.04);
    --grid-strong: rgba(255,255,255,0.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: var(--bg); color: var(--text-2);
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
  }
  body { min-height: 100vh; padding: 28px 32px 36px; overflow-x: hidden; }
  .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
  .brand { display: flex; align-items: center; gap: 14px; }
  .brand-mark { width: 36px; height: 36px; background: linear-gradient(135deg, #E07A1A, #C25E0F); border-radius: 8px; display: grid; place-items: center; font-weight: 700; font-size: 14px; color: var(--bg); }
  .brand-mark-logo { width: 52px; height: 52px; object-fit: contain; border-radius: 8px; flex-shrink: 0; }
  .brand-wordmark { height: 52px; width: auto; opacity: 0.9; }
  .brand-title { font-size: 32px; font-weight: 600; letter-spacing: -0.6px; color: var(--text); margin-top: 1px; }
  .header-right { display: flex; align-items: center; gap: 10px; }
  .live-badge { display: flex; align-items: center; gap: 8px; padding: 6px 12px; background: var(--green-bg); border: 1px solid rgba(74,222,128,0.25); border-radius: 6px; font-size: 12px; color: var(--green); font-weight: 500; }
  .live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green); animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .clock { font-size: 12px; color: var(--muted); padding: 6px 10px; background: var(--surface); border: 1px solid var(--border); border-radius: 6px; font-variant-numeric: tabular-nums; min-width: 80px; text-align: center; }
  .mode-toggle { padding: 7px 14px; background: var(--surface-2); border: 1px solid var(--border); border-radius: 6px; color: var(--text-2); font-size: 12px; font-family: inherit; cursor: pointer; font-weight: 500; transition: all 0.15s; }
  .mode-toggle:hover { border-color: var(--border-strong); background: #222226; }
  .mode-toggle.browse-mode { background: rgba(224,122,26,0.12); border-color: rgba(224,122,26,0.4); color: var(--brand); }
  .filter-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; gap: 16px; flex-wrap: wrap; }
  .filter-bar { display: inline-flex; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 3px; gap: 2px; }
  .filter-btn { background: transparent; border: none; color: var(--muted); padding: 6px 14px; font-size: 12px; font-family: inherit; border-radius: 5px; cursor: pointer; transition: all 0.15s; font-weight: 500; }
  .filter-btn:hover { color: var(--text-2); }
  .filter-btn.active { background: var(--border); color: var(--text); }
  .last-updated { font-size: 12px; color: var(--muted-2); }
  .shift-group { display: flex; align-items: center; gap: 8px; }
  .shift-bar { display: inline-flex; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 3px; gap: 2px; }
  .shift-btn { background: transparent; border: none; color: var(--muted); padding: 6px 14px; font-size: 12px; font-family: inherit; border-radius: 5px; cursor: pointer; transition: all 0.15s; font-weight: 500; display: inline-flex; align-items: center; gap: 6px; }
  .shift-btn .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--muted-2); }
  .shift-btn[data-shift="day"] .dot { background: var(--day); }
  .shift-btn[data-shift="night"] .dot { background: var(--night); }
  .shift-btn:hover { color: var(--text-2); }
  .shift-btn.active { background: var(--border); color: var(--text); }
  .kpi-strip { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 16px; }
  .kpi-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 18px 20px; }
  .kpi-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .kpi-label { font-size: 12px; color: var(--muted); font-weight: 500; }
  .kpi-value { font-size: 36px; font-weight: 600; color: var(--text); letter-spacing: -1px; line-height: 1; font-variant-numeric: tabular-nums; }
  .kpi-sub { font-size: 11px; color: var(--muted-2); margin-top: 8px; }
  .split-row { display: flex; gap: 16px; align-items: baseline; }
  .split-col { display: flex; flex-direction: column; }
  .split-divider { width: 1px; align-self: stretch; background: var(--border); }
  .split-num { font-size: 30px; font-weight: 600; line-height: 1; font-variant-numeric: tabular-nums; letter-spacing: -0.8px; }
  .split-num.day { color: var(--day); }
  .split-num.night { color: var(--night); }
  .split-label { font-size: 11px; color: var(--muted-2); margin-top: 4px; }
  .split-bar { margin-top: 14px; height: 4px; background: rgba(255,255,255,0.06); border-radius: 999px; overflow: hidden; display: flex; }
  .shift-bar-day { background: var(--day); }
  .shift-bar-night { background: var(--night); }
  .chart-row { display: grid; grid-template-columns: 1.5fr 1fr; gap: 12px; margin-bottom: 12px; }
  .chart-card { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 18px 20px; }
  .chart-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
  .chart-title { font-size: 13px; font-weight: 500; color: var(--text); }
  .chart-meta { font-size: 11px; color: var(--muted-2); }
  .chart-canvas-wrap { position: relative; height: 200px; }
  .chart-canvas-wrap.tall { height: 260px; }
  .section-divider { display: flex; align-items: baseline; justify-content: space-between; margin: 24px 0 16px; }
  .section-title { font-size: 16px; font-weight: 600; color: var(--text); letter-spacing: -0.2px; }
  .section-meta { font-size: 12px; color: var(--muted-2); }
  .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .coord-table { width: 100%; border-collapse: collapse; }
  .coord-table th { font-size: 11px; font-weight: 500; color: var(--muted); padding: 14px 18px; text-align: center; border-bottom: 1px solid var(--border); background: var(--surface-2); cursor: pointer; user-select: none; }
  .coord-table th:first-child { text-align: left; }
  .coord-table th:hover { color: var(--text-2); }
  .coord-table th.sorted { color: var(--text); }
  .sort-arrow { margin-left: 4px; font-size: 10px; }
  .coord-table td { padding: 14px 18px; border-bottom: 1px solid var(--border); font-size: 13px; color: var(--text-2); font-variant-numeric: tabular-nums; text-align: center; }
  .coord-table td:first-child { text-align: left; }
  .coord-table tr:last-child td { border-bottom: none; }
  .coord-table tbody tr:hover { background: rgba(255,255,255,0.02); }
  .coord-name-cell { font-weight: 600; color: var(--text) !important; }
  .shift-pill { display: inline-block; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 600; }
  .shift-pill.day { background: var(--day-bg); color: var(--day); }
  .shift-pill.night { background: var(--night-bg); color: var(--night); }
  .shift-pill.mixed { background: var(--purple-bg); color: var(--purple); }
  .shift-pill.unknown { background: rgba(255,255,255,0.06); color: var(--muted); }
  .bph-cell.green { color: var(--green); font-weight: 600; }
  .bph-cell.orange { color: var(--orange); font-weight: 600; }
  .bph-cell.red { color: var(--red); font-weight: 600; }
  .state-msg { text-align: center; padding: 60px 20px; color: var(--muted-2); font-size: 14px; }
</style>
</head>
<body>

<div class="header">
  <div class="brand">
    <img src="../../shared/wrench_transparent.png" alt="" class="brand-mark-logo" onerror="this.style.display='none'; this.insertAdjacentHTML('afterend', '<div class=\'brand-mark\'>R</div>');">
    <div>
      <div class="brand-title">Coordinators Dashboard</div>
    </div>
  </div>
  <div class="header-right">
    <img src="../../shared/repairbit-logo.png" alt="RepairBit" class="brand-wordmark" onerror="this.style.display='none'">
    <div class="live-badge"><span class="live-dot"></span>Live</div>
    <span class="clock" id="clock">--:--:--</span>
    <button class="mode-toggle" id="modeToggle" onclick="toggleMode()">Presentation</button>
  </div>
</div>

<div class="filter-row">
  <div class="filter-bar">
    <button class="filter-btn active" data-range="today" onclick="setRange('today')">Today</button>
    <button class="filter-btn" data-range="week" onclick="setRange('week')">Week</button>
    <button class="filter-btn" data-range="month" onclick="setRange('month')">Month</button>
    <button class="filter-btn" data-range="quarter" onclick="setRange('quarter')">Quarter</button>
    <button class="filter-btn" data-range="ytd" onclick="setRange('ytd')">YTD</button>
    <button class="filter-btn" data-range="all" onclick="setRange('all')">All Time</button>
  </div>

  <div class="shift-group">
    <div class="shift-bar">
      <button class="shift-btn active" data-shift="all" onclick="setShift('all')">All Shifts</button>
      <button class="shift-btn" data-shift="day" onclick="setShift('day')"><span class="dot"></span>Day</button>
      <button class="shift-btn" data-shift="night" onclick="setShift('night')"><span class="dot"></span>Night</button>
    </div>
    <span class="last-updated" id="lastUpdated">Connecting...</span>
  </div>
</div>

<div class="kpi-strip">
  <div class="kpi-card">
    <div class="kpi-head"><span class="kpi-label">Total Boards</span></div>
    <div class="kpi-value" id="s-units">—</div>
    <div class="kpi-sub" id="s-units-sub">—</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-head"><span class="kpi-label">Boards per Hour</span></div>
    <div class="split-row">
      <div class="split-col">
        <span class="split-num day" id="s-bph-day">—</span>
        <span class="split-label">Day</span>
      </div>
      <div class="split-divider"></div>
      <div class="split-col">
        <span class="split-num night" id="s-bph-night">—</span>
        <span class="split-label">Night</span>
      </div>
    </div>
    <div class="kpi-sub" id="s-bph-sub">—</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-head"><span class="kpi-label">Active Coordinators</span></div>
    <div class="split-row">
      <div class="split-col">
        <span class="split-num day" id="s-coords-day">—</span>
        <span class="split-label">Day</span>
      </div>
      <div class="split-divider"></div>
      <div class="split-col">
        <span class="split-num night" id="s-coords-night">—</span>
        <span class="split-label">Night</span>
      </div>
    </div>
    <div class="kpi-sub" id="s-coords-sub">—</div>
  </div>
  <div class="kpi-card">
    <div class="kpi-head"><span class="kpi-label">Day vs Night Boards</span></div>
    <div class="split-row">
      <div class="split-col">
        <span class="split-num day" id="s-day">—</span>
        <span class="split-label">Day</span>
      </div>
      <div class="split-divider"></div>
      <div class="split-col">
        <span class="split-num night" id="s-night">—</span>
        <span class="split-label">Night</span>
      </div>
    </div>
    <div class="split-bar" id="s-shift-bar"></div>
  </div>
</div>

<div class="chart-row">
  <div class="chart-card">
    <div class="chart-head">
      <div class="chart-title">Daily Trend</div>
      <span class="chart-meta">Last 14 days</span>
    </div>
    <div class="chart-canvas-wrap"><canvas id="trendChart"></canvas></div>
  </div>
  <div class="chart-card">
    <div class="chart-head">
      <div class="chart-title">Top 10 Coordinators</div>
      <span class="chart-meta">By boards</span>
    </div>
    <div class="chart-canvas-wrap"><canvas id="leadersChart"></canvas></div>
  </div>
</div>

<div class="chart-card" style="margin-bottom: 12px;">
  <div class="chart-head">
    <div class="chart-title">Top Models Processed</div>
    <span class="chart-meta">Most frequent</span>
  </div>
  <div class="chart-canvas-wrap"><canvas id="modelsChart"></canvas></div>
</div>

<div class="section-divider">
  <div class="section-title">Coordinator Breakdown</div>
  <div class="section-meta" id="tableMeta">—</div>
</div>

<div class="table-wrap" id="tableWrap">
  <div class="state-msg">Loading coordinator data...</div>
</div>

<script>
  const WORKER_URL = "https://lab-dashboard-api.kmead.workers.dev";
  const REFRESH_MS = 30000;
  const HOURS_PER_DAY = 6.5;

  let currentData = null;
  let currentRange = "today", currentShift = "all";
  let trendChart = null, leadersChart = null, modelsChart = null;
  let sortKey = "units", sortDir = "desc";
  let browseMode = false, refreshTimer = null;

  const COLORS = {
    text: '#FAFAFB', text2: '#ECECEE', muted: '#9A9AA1', muted2: '#6E6E76',
    grid: 'rgba(255,255,255,0.04)', green: '#4ADE80', orange: '#FBBF24',
    red: '#F87171', purple: '#C084FC', brand: '#E07A1A',
    day: '#FBBF24', night: '#818CF8'
  };

  function tickClock() {
    const c = document.getElementById('clock');
    if (c) c.textContent = new Date().toLocaleTimeString('en-US', { hour12: false });
  }
  setInterval(tickClock, 1000);
  tickClock();

  function setRange(range) {
    if (range === currentRange) return;
    currentRange = range;
    document.querySelectorAll(".filter-btn").forEach(b => b.classList.toggle("active", b.dataset.range === range));
    document.getElementById("lastUpdated").textContent = "Loading " + range + "...";
    fetchData();
  }

  function setShift(shift) {
    if (shift === currentShift) return;
    currentShift = shift;
    document.querySelectorAll(".shift-btn").forEach(b => b.classList.toggle("active", b.dataset.shift === shift));
    renderAll();
  }

  function toggleMode() {
    browseMode = !browseMode;
    const btn = document.getElementById("modeToggle");
    if (browseMode) {
      btn.textContent = "Browse";
      btn.classList.add("browse-mode");
      if (refreshTimer) { clearInterval(refreshTimer); refreshTimer = null; }
    } else {
      btn.textContent = "Presentation";
      btn.classList.remove("browse-mode");
      fetchData();
      refreshTimer = setInterval(fetchData, REFRESH_MS);
    }
  }

  async function fetchData() {
    try {
      const res = await fetch(WORKER_URL + "?type=coordinator&range=" + encodeURIComponent(currentRange) + "&t=" + Date.now());
      const json = await res.json();
      if (json.error) throw new Error(json.error);
      currentData = json;
      renderAll();
      document.getElementById("lastUpdated").textContent =
        "Updated " + new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
    } catch (e) {
      document.getElementById("lastUpdated").textContent = "Connection error — retrying";
    }
  }

  function fmtBPH(v) { return Number(v).toFixed(2); }
  function bphClass(bph) {
    if (bph >= 8) return "green";
    if (bph >= 4) return "orange";
    return "red";
  }

  function getActiveSlice() {
    if (!currentData) return null;
    return currentData[currentShift] || currentData.all;
  }

  function renderTrendChart(trend) {
    const ctx = document.getElementById('trendChart');
    if (trendChart) trendChart.destroy();
    trendChart = new Chart(ctx, {
      data: {
        labels: trend.labels,
        datasets: [
          {
            type: 'bar', label: 'Boards', data: trend.units,
            backgroundColor: 'rgba(74,222,128,0.55)', borderColor: COLORS.green,
            borderWidth: 0, borderRadius: 4, yAxisID: 'y', order: 2
          },
          {
            type: 'line', label: 'BPH', data: trend.bphs,
            borderColor: COLORS.text, backgroundColor: 'transparent',
            borderWidth: 1.5, borderDash: [4, 3], tension: 0.35,
            yAxisID: 'y1', pointRadius: 3, pointBackgroundColor: COLORS.text,
            pointBorderColor: '#0A0A0B', pointBorderWidth: 1, order: 1
          }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { mode: 'index', intersect: false, backgroundColor: '#1A1A1D', borderColor: '#27272B', borderWidth: 1, titleColor: COLORS.text, bodyColor: COLORS.text2, padding: 10 }
        },
        scales: {
          x: { ticks: { font: { family: 'Inter', size: 11 }, color: COLORS.muted2, maxRotation: 0 }, grid: { color: COLORS.grid, drawBorder: false } },
          y: { position: 'left', min: 0, ticks: { font: { family: 'Inter', size: 11 }, color: COLORS.green }, grid: { color: COLORS.grid, drawBorder: false } },
          y1: { position: 'right', min: 0, ticks: { font: { family: 'Inter', size: 11 }, color: COLORS.text2 }, grid: { display: false } }
        }
      }
    });
  }

  function renderLeadersChart(leaders) {
    const labels = leaders.map(t => t.name);
    const data = leaders.map(t => t.units);
    const colors = leaders.map(t => {
      if (t.primary === "Day") return COLORS.day;
      if (t.primary === "Night") return COLORS.night;
      return COLORS.purple;
    });
    const ctx = document.getElementById('leadersChart');
    if (leadersChart) leadersChart.destroy();
    leadersChart = new Chart(ctx, {
      type: 'bar',
      data: { labels, datasets: [{ label: 'Boards', data, backgroundColor: colors, borderColor: 'transparent', borderWidth: 0, borderRadius: 4 }] },
      options: {
        indexAxis: 'y', responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { backgroundColor: '#1A1A1D', borderColor: '#27272B', borderWidth: 1, titleColor: COLORS.text, bodyColor: COLORS.text2, padding: 10, callbacks: { label: c => c.parsed.x.toLocaleString() + ' boards' } }
        },
        scales: {
          x: { min: 0, ticks: { font: { family: 'Inter', size: 11 }, color: COLORS.muted2 }, grid: { color: COLORS.grid, drawBorder: false } },
          y: { ticks: { font: { family: 'Inter', size: 12 }, color: COLORS.text2 }, grid: { display: false } }
        }
      }
    });
  }

  function renderModelsChart(models) {
    const labels = models.map(s => s.name);
    const data = models.map(s => s.count);
    const ctx = document.getElementById('modelsChart');
    if (modelsChart) modelsChart.destroy();
    modelsChart = new Chart(ctx, {
      type: 'bar',
      data: { labels, datasets: [{ label: 'Boards', data, backgroundColor: 'rgba(224,122,26,0.7)', borderColor: 'transparent', borderWidth: 0, borderRadius: 4 }] },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { display: false },
          tooltip: { backgroundColor: '#1A1A1D', borderColor: '#27272B', borderWidth: 1, titleColor: COLORS.text, bodyColor: COLORS.text2, padding: 10, callbacks: { label: c => c.parsed.y.toLocaleString() + ' boards' } }
        },
        scales: {
          x: {
            ticks: {
              font: { family: 'Inter', size: 10 }, color: COLORS.muted2,
              maxRotation: 30, minRotation: 0,
              callback: function(v) { const lbl = this.getLabelForValue(v); return lbl.length > 18 ? lbl.substr(0, 16) + '…' : lbl; }
            },
            grid: { color: COLORS.grid, drawBorder: false }
          },
          y: { min: 0, ticks: { font: { family: 'Inter', size: 11 }, color: COLORS.muted2 }, grid: { color: COLORS.grid, drawBorder: false } }
        }
      }
    });
  }

  function renderTable(coordStats) {
    const wrap = document.getElementById("tableWrap");
    const meta = document.getElementById("tableMeta");
    if (coordStats.length === 0) {
      wrap.innerHTML = '<div class="state-msg">No data for this filter.</div>';
      meta.textContent = "0 coordinators";
      return;
    }
    meta.textContent = coordStats.length + " coordinator" + (coordStats.length === 1 ? "" : "s");

    const sorted = [...coordStats].sort((a, b) => {
      const av = a[sortKey], bv = b[sortKey];
      let cmp;
      if (typeof av === "string") cmp = av.localeCompare(bv);
      else cmp = av - bv;
      return sortDir === "desc" ? -cmp : cmp;
    });

    const arrow = sortDir === "desc" ? "▼" : "▲";
    const cols = [
      { key: "name", label: "Coordinator" },
      { key: "primary", label: "Shift" },
      { key: "units", label: "Boards" },
      { key: "days", label: "Days Worked" },
      { key: "bph", label: "BPH" }
    ];

    const headHTML = cols.map(c => {
      const cls = c.key === sortKey ? " sorted" : "";
      const ar = c.key === sortKey ? '<span class="sort-arrow">' + arrow + '</span>' : '';
      return '<th class="' + cls.trim() + '" onclick="sortBy(\'' + c.key + '\')">' + c.label + ar + '</th>';
    }).join("");

    const bodyHTML = sorted.map(c => {
      const pillCls = c.primary.toLowerCase();
      const bCls = bphClass(c.bph);
      return '<tr>' +
        '<td class="coord-name-cell">' + esc(c.name) + '</td>' +
        '<td><span class="shift-pill ' + pillCls + '">' + esc(c.primary) + '</span></td>' +
        '<td>' + c.units.toLocaleString() + '</td>' +
        '<td>' + c.days.toLocaleString() + '</td>' +
        '<td class="bph-cell ' + bCls + '">' + fmtBPH(c.bph) + '</td>' +
      '</tr>';
    }).join("");

    wrap.innerHTML = '<table class="coord-table"><thead><tr>' + headHTML + '</tr></thead><tbody>' + bodyHTML + '</tbody></table>';
  }

  function sortBy(key) {
    if (sortKey === key) {
      sortDir = sortDir === "desc" ? "asc" : "desc";
    } else {
      sortKey = key;
      sortDir = (key === "name" || key === "primary") ? "asc" : "desc";
    }
    renderAll();
  }

  function renderAll() {
    const slice = getActiveSlice();
    if (!slice) return;
    const summary = slice.summary;

    // Total Boards
    document.getElementById("s-units").textContent = summary.units.toLocaleString();
    document.getElementById("s-units-sub").textContent =
      summary.coordDays + " coordinator-day" + (summary.coordDays === 1 ? "" : "s") + " logged";

    // BPH split
    document.getElementById("s-bph-day").textContent = fmtBPH(summary.dayBph);
    document.getElementById("s-bph-night").textContent = fmtBPH(summary.nightBph);
    let bphSub = "Combined " + fmtBPH(summary.bph) + " · " + HOURS_PER_DAY + " hrs/day";
    if (summary.dayBph > 0 && summary.nightBph > 0) {
      if (summary.dayBph > summary.nightBph) {
        const lead = ((summary.dayBph - summary.nightBph) / summary.nightBph) * 100;
        bphSub = "Day leading by " + lead.toFixed(0) + "% · " + HOURS_PER_DAY + " hrs/day";
      } else if (summary.nightBph > summary.dayBph) {
        const lead = ((summary.nightBph - summary.dayBph) / summary.dayBph) * 100;
        bphSub = "Night leading by " + lead.toFixed(0) + "% · " + HOURS_PER_DAY + " hrs/day";
      } else {
        bphSub = "Tied · " + HOURS_PER_DAY + " hrs/day";
      }
    }
    document.getElementById("s-bph-sub").textContent = bphSub;

    // Active Coordinators
    document.getElementById("s-coords-day").textContent = summary.dayCoords.toLocaleString();
    document.getElementById("s-coords-night").textContent = summary.nightCoords.toLocaleString();
    document.getElementById("s-coords-sub").textContent = summary.coords > 0
      ? summary.coords + " total · " + Math.round(summary.units / summary.coords).toLocaleString() + " avg boards/coord"
      : "—";

    // Day vs Night
    document.getElementById("s-day").textContent = summary.day.toLocaleString();
    document.getElementById("s-night").textContent = summary.night.toLocaleString();
    const total = summary.day + summary.night;
    const sb = document.getElementById("s-shift-bar");
    if (total > 0) {
      const dayPct = (summary.day / total) * 100;
      const nightPct = (summary.night / total) * 100;
      sb.innerHTML = '<div class="shift-bar-day" style="width:' + dayPct + '%;"></div>' +
                     '<div class="shift-bar-night" style="width:' + nightPct + '%;"></div>';
    } else {
      sb.innerHTML = '';
    }

    // Charts
    renderTrendChart(slice.trend);
    renderLeadersChart(slice.leaders);
    renderModelsChart(slice.models);

    // Table
    renderTable(slice.coordStats);
  }

  function esc(str) {
    return String(str).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  fetchData();
  refreshTimer = setInterval(fetchData, REFRESH_MS);
</script>
</body>
</html>
